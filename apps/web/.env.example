# Public site URL used in share links + snippets (landing, docs).
# No trailing slash needed. Falls back to https://peekhook.dev if unset.
VITE_WEB_URL=https://peekhook.dev

# Base URL the built app calls for /api requests (used in inspector share links).
# Leave empty to use same-origin relative paths.
VITE_API_URL=

# Where the Vite dev server proxies /api and /mcp (dev only).
VITE_API_TARGET=http://localhost:3000
